@using Vizor.ECharts;

<Vizor.ECharts.EChart Options="@options" DataLoader="LoadChartData" Width="800px" Height="400px" />

@code {

	// roughly based on https://echarts.apache.org/examples/en/editor.html?c=area-time-axis

	private ChartOptions options = new()
		{
			Tooltip = new()
			{
				Trigger = TooltipTrigger.Axis,
                Position = new JavascriptFunction(@"function (pt) {
                  return [pt[0], '10%'];
                }")
			},
			Toolbox = new()
			{
				Feature = new()
				{
					DataZoom = new()
					{
						YAxisIndex = "none"
					}
				}
			},
            Title = new()
            {
                Left = "center",
                Text = "Time Series Area Chart"
            },
			XAxis = new()
			{
				Type = AxisType.Time,
				BoundaryGap = false
			},
			YAxis = new()
			{
				Type = AxisType.Value,
				BoundaryGap = new(0, "100%")
			},
			DataZoom = new()
			{
				new InsideDataZoom()
				{
					Start = 0,
					End = 20
				}, 
                new SliderDataZoom()
                {
                    Start = 0,
                    End = 20
                }
			},
			Series = new()
			{
				new LineSeries()
				{
					AreaStyle = new() {},
                    Name = "Fake data",
					ShowSymbol = false,
					Smooth = true
				}
			}
		};

	private void LoadChartData()
	{
		var now = new DateTime(2023, 08, 01);
        @* var minutes = 20000; *@
        var minutes = (24 * 60 * 7); // one week of minute data
        @* minutes *= 30;  // increase to 30 weeks *@
		var values = new List<SeriesData<DateTime, int>>(minutes);
		var rnd = new Random();

		for (int i = 0; i < minutes; ++i)
		{
			values.Add(new (now + TimeSpan.FromMinutes(i), 150-rnd.Next(350)));
		}

		(options.Series![0] as LineSeries)!.Data = values;
	}
}