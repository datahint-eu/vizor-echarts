@using Vizor.ECharts;

<Vizor.ECharts.EChart Options="@options" Width="800px" Height="400px" />

@code {

	// see https://echarts.apache.org/examples/en/editor.html?c=area-basic

	private ChartOptions options = new()
		{
			XAxis = new()
			{
				Type = AxisType.Category,
				BoundaryGap = false,
				Data = new List<AxisData> { new AxisData() { Value = "Mon" }, new AxisData() { Value = "Tue" }, new AxisData() { Value = "Wed" }, new AxisData() { Value = "Thu" }, new AxisData() { Value = "Fri" }, new AxisData() { Value = "Sat" }, new AxisData() { Value = "Sun" } }
			},
			YAxis = new()
			{
				Type = AxisType.Value
			},
			Series = new()
			{
				new LineSeries()
				{
                    Data = new int[] { 150, 230, 224, 218, 135, 147, 260 },
					@* Data = new List<LineSeriesData> {new LineSeriesData() { Value = 820 }, new LineSeriesData() { Value = 932 }, new LineSeriesData() { Value = 901 }, new LineSeriesData() { Value = 934 }, new LineSeriesData() { Value = 1290 }, new LineSeriesData() { Value = 1330 }, new LineSeriesData() { Value = 1320 } }, *@
					AreaStyle = new() {}
				}
			}
		};
}