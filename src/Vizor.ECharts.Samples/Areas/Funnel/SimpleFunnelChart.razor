@using Vizor.ECharts;

<Vizor.ECharts.EChart Options="@options" Width="800px" Height="800px" />

@code {

	// see https://echarts.apache.org/examples/en/editor.html?c=funnel

	private ChartOptions options = new()
		{
			Title = new()
			{
				Text = "Funnel"	
			},
			Tooltip = new()
			{
				Trigger = TooltipTrigger.Item,
				Formatter = "{a} <br/>{b} : {c}%"
			},
			Legend = new()
			{
				Data = new List<LegendData> { new LegendData() { Name = "Show" }, new LegendData() { Name = "Click" }, new LegendData() { Name = "Visit" }, new LegendData() { Name = "Inquiry" }, new LegendData() { Name = "Order" } }
			},
			Series = new()
			{
				new FunnelSeries()
				{
					Name = "Funnel",
					Left = "10%",
					Top = 60,
					Bottom = 60,
					Width = "80%",
					Min = 0,
					Max = 100,
					MinSize = "0%",
					MaxSize = "100%",
					Sort = FunnelSortOrder.Descending,
					Gap = 2,
					Label = new()
					{
						Show = true,
						Position = LabelPosition.Inside
					},
					LabelLine = new()
					{
						Length = 10,
						LineStyle = new()
						{
							Width = 1,
							Type = LineTypeStyle.Solid
						}
					},
					ItemStyle = new()
					{
						BorderColor = "#fff",
						BorderWidth = 1
					},
					Emphasis = new()
					{
						Label = new()
						{
							FontSize = 20
						}
					},
					Data = new List<FunnelSeriesData>()
					{
						new() { Name = "Visit", Value = 60 },
						new() { Name = "Inquiry", Value = 40 },
						new() { Name = "Order", Value = 20 },
						new() { Name = "Click", Value = 80 },
						new() { Name = "Show", Value = 100 }
					}
				}
			}
		};
}